rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role in ["student", "tutor"];
      // Role and identity are locked once created.
      allow update, delete: if false;
    }

    match /rosterLinks/{linkId} {
      allow read: if request.auth != null
        && (resource.data.tutorUid == request.auth.uid || resource.data.studentUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.tutorUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.tutorUid == request.auth.uid;
      allow update: if false;
    }

    match /classes/{classId} {
      // A class can have multiple attendees (studentUids), unlike tasks which stay one-per-student.
      allow read: if request.auth != null
        && (resource.data.tutorUid == request.auth.uid || request.auth.uid in resource.data.studentUids);
      allow create: if request.auth != null
        && request.resource.data.tutorUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.tutorUid == request.auth.uid;
    }

    match /qnaThreads/{threadId} {
      allow read: if request.auth != null
        && (resource.data.tutorUid == request.auth.uid || resource.data.studentUid == request.auth.uid);
      allow create: if request.auth != null
        && (request.resource.data.tutorUid == request.auth.uid || request.resource.data.studentUid == request.auth.uid);
      // Either participant can post messages / update status, but neither can reassign the thread to different people.
      allow update: if request.auth != null
        && (resource.data.tutorUid == request.auth.uid || resource.data.studentUid == request.auth.uid)
        && request.resource.data.tutorUid == resource.data.tutorUid
        && request.resource.data.studentUid == resource.data.studentUid;
      allow delete: if request.auth != null
        && (resource.data.tutorUid == request.auth.uid || resource.data.studentUid == request.auth.uid);
    }

    match /tasks/{taskId} {
      allow read: if request.auth != null
        && (resource.data.tutorUid == request.auth.uid || resource.data.studentUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.tutorUid == request.auth.uid;
      // Tutor attaches files / edits the task; student submits. Neither can reassign the task to different people.
      allow update: if request.auth != null
        && (resource.data.tutorUid == request.auth.uid || resource.data.studentUid == request.auth.uid)
        && request.resource.data.tutorUid == resource.data.tutorUid
        && request.resource.data.studentUid == resource.data.studentUid;
      allow delete: if request.auth != null && resource.data.tutorUid == request.auth.uid;
    }
  }
}
